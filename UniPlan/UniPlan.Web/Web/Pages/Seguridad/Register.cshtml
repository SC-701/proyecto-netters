@page
@model Web.Pages.Seguridad.RegisterModel
@{
    ViewData["Title"] = "Registro";
    Layout = "_AccountLayout";
}

<div class="flex flex-col max-w-[520px] w-full bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">

    <!-- Banner superior -->
    <div class="h-32 bg-primary/10 flex items-center justify-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-transparent"></div>
        <div class="relative z-10 text-center">
            <span class="material-symbols-outlined text-primary text-5xl">school</span>
        </div>
    </div>

    <div class="p-8">
        <!-- Título -->
        <div class="mb-8">
            <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-black leading-tight tracking-tight">Crear cuenta</h1>
            <p class="text-slate-500 dark:text-slate-400 text-base mt-2">Únete a la comunidad académica y organiza tu futuro.</p>
        </div>

        <!-- Mensajes de validación generales -->
        <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600 dark:text-red-400"></div>

        <form method="post" class="space-y-5" onsubmit="return validarPasswords()">
            @Html.AntiForgeryToken()

            <!-- Nombre completo -->
            <div>
                <label asp-for="usuario.NombreUsuario" class="block text-slate-700 dark:text-slate-300 text-sm font-semibold mb-2">
                    Nombre completo
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">person</span>
                    <input asp-for="usuario.NombreUsuario"
                           class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-slate-400"
                           placeholder="Ej. Juan Pérez" />
                </div>
                <span asp-validation-for="usuario.NombreUsuario" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Email -->
            <div>
                <label asp-for="usuario.CorreoElectronico" class="block text-slate-700 dark:text-slate-300 text-sm font-semibold mb-2">
                    Correo electrónico
                </label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">mail</span>
                    <input asp-for="usuario.CorreoElectronico"
                           class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-slate-400"
                           placeholder="usuario@universidad.edu" />
                </div>
                <span asp-validation-for="usuario.CorreoElectronico" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Contraseña y confirmación -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label asp-for="usuario.Password" class="block text-slate-700 dark:text-slate-300 text-sm font-semibold mb-2">
                        Contraseña
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">lock</span>
                        <input asp-for="usuario.Password"
                               type="password"
                               id="passwordInput"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-slate-400"
                               placeholder="••••••••" />
                        <button type="button" onclick="togglePassword('passwordInput','toggleIconPassword')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                            <span id="toggleIconPassword" class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="usuario.Password" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="usuario.ConfirmarPassword" class="block text-slate-700 dark:text-slate-300 text-sm font-semibold mb-2">
                        Confirmar
                    </label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[20px]">lock_clock</span>
                        <input asp-for="usuario.ConfirmarPassword"
                               type="password"
                               id="confirmPasswordInput"
                               class="w-full pl-10 pr-4 py-3 rounded-lg border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all placeholder:text-slate-400"
                               placeholder="••••••••" />
                        <button type="button" onclick="togglePassword('confirmPasswordInput','toggleIconConfirm')" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 dark:hover:text-slate-200">
                            <span id="toggleIconConfirm" class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="usuario.ConfirmarPassword" class="text-xs text-red-500 mt-1 block"></span>
                    <span id="errorPassword" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>


            <!-- Botón submit -->
            <div class="pt-4">
                <button type="submit"
                        class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-lg transition-all shadow-md shadow-primary/20 flex items-center justify-center gap-2">
                    Registrarse
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </div>
        </form>

        <!-- Link a login -->
        <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800 text-center">
            <p class="text-slate-600 dark:text-slate-400 text-sm">
                ¿Ya tienes una cuenta?
                <a asp-page="/Seguridad/Login" class="text-primary font-bold hover:underline">Iniciar sesión</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Para ver contraseña (el ojito)
        function togglePassword(inputId, iconId) {
            var passwordInput = document.getElementById(inputId);
            var toggleIcon = document.getElementById(iconId);

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                toggleIcon.textContent = "visibility_off";
            } else {
                passwordInput.type = "password";
                toggleIcon.textContent = "visibility";
            }
        }

        // Para ver que sean iguales
        function validarPasswords() {
            var pass = document.getElementById("passwordInput").value;
            var confirm = document.getElementById("confirmPasswordInput").value;
            var error = document.getElementById("errorPassword");

            if (pass !== confirm) {
                error.textContent = "Las contraseñas no coinciden";
                return false;
            }

            error.textContent = "";
            return true;
        }
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("confirmPasswordInput").addEventListener("input", function () {
                var pass = document.getElementById("passwordInput").value;
                var confirm = this.value;
                var error = document.getElementById("errorPassword");

                if (pass === confirm) {
                    error.textContent = "";
                }
            });
        });
    </script>
}

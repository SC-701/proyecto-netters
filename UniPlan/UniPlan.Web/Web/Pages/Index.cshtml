@page
@model IndexModel
@{
    ViewData["Title"] = "Planificador Académico Inteligente";
    Layout = "_Layout";
}

<!-- HERO -->
<section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

        <!-- Texto hero -->
        <div class="flex flex-col space-y-8">
            <div class="space-y-4">
                <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
                    Nuevo: Integración con Calendarios
                </span>
                <h1 class="text-5xl font-extrabold leading-[1.1] tracking-tight text-slate-900 dark:text-white md:text-6xl">
                    Toma el control de <span class="text-primary">tu carrera</span>
                </h1>
                <p class="text-lg leading-relaxed text-slate-600 dark:text-slate-400 max-w-xl">
                    Planifica tus materias, valida requisitos y organiza tu horario semanal en un solo lugar.
                    La herramienta definitiva para estudiantes universitarios.
                </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4">
                <a asp-page="/Account/Register"
                   class="rounded-xl bg-primary px-8 py-4 text-base font-bold text-white shadow-lg shadow-primary/20 hover:bg-primary/90 transition-all text-center">
                    Empezar gratis
                </a>
            </div>
            <div class="flex items-center gap-4 text-sm text-slate-500">
                <div class="flex -space-x-2">
                    <div class="h-8 w-8 rounded-full border-2 border-background-light bg-slate-200"></div>
                    <div class="h-8 w-8 rounded-full border-2 border-background-light bg-slate-300"></div>
                    <div class="h-8 w-8 rounded-full border-2 border-background-light bg-slate-400"></div>
                </div>
                <span>Unido por más de @Model.StudentCount estudiantes</span>
            </div>
        </div>

        <!-- Imagen / preview -->
        <div class="relative">
            <div class="aspect-video w-full rounded-2xl bg-white p-2 shadow-2xl dark:bg-slate-800">
                <div class="h-full w-full rounded-xl bg-slate-100 dark:bg-slate-900 overflow-hidden"
                     style="background-image: url('@Model.HeroImageUrl'); background-size: cover; background-position: center;">
                </div>
            </div>
            <!-- Badge de progreso -->
            <div class="absolute -bottom-6 -left-6 hidden md:block rounded-xl bg-white dark:bg-slate-800 p-4 shadow-xl border border-slate-100 dark:border-slate-700">
                <div class="flex items-center gap-3">
                    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-green-100 text-green-600">
                        <span class="material-symbols-outlined">check_circle</span>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-slate-500">Progreso total</p>
                        <p class="text-sm font-bold text-slate-900 dark:text-white">@Model.ProgressPercent% Completado</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="bg-slate-50 dark:bg-slate-900/50 py-24">
    <div class="mx-auto max-w-7xl px-6">
        <div class="mb-16 text-center">
            <h2 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
                Todo lo que necesitas para graduarte a tiempo
            </h2>
            <p class="mt-4 text-lg text-slate-600 dark:text-slate-400">
                Herramientas diseñadas específicamente para la vida universitaria moderna.
            </p>
        </div>
        <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
            @foreach (var feature in Model.Features)
            {
                <div class="group rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-800 p-8 shadow-sm hover:shadow-md transition-all">
                    <div class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-transform group-hover:scale-110">
                        <span class="material-symbols-outlined">@feature.Icon</span>
                    </div>
                    <h3 class="mb-3 text-xl font-bold text-slate-900 dark:text-white">@feature.Title</h3>
                    <p class="text-slate-600 dark:text-slate-400 leading-relaxed">@feature.Description</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="mx-auto max-w-5xl px-6 py-24 text-center">
    <div class="rounded-3xl bg-primary px-8 py-16 shadow-2xl shadow-primary/30">
        <h2 class="text-3xl font-extrabold text-white sm:text-4xl">¿Listo para organizar tu semestre?</h2>
        <p class="mx-auto mt-6 max-w-xl text-lg text-white/90">
            Únete a miles de estudiantes que ya optimizan su tiempo con UniPlan.
            Empieza hoy mismo y deja de preocuparte por el papeleo.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a asp-page="/Account/Register"
               class="rounded-xl bg-white px-8 py-4 text-base font-bold text-primary hover:bg-slate-50 transition-all">
                Empezar ahora - Es gratis
            </a>
        </div>
    </div>
</section>
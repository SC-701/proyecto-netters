@page "/Admin/Cursos"
@model Web.Pages.Admin.Cursos.IndexModel
@{
    ViewData["Title"] = "Gestión de Cursos";
    ViewData["ActivePage"] = "Cursos";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<!-- Breadcrumb + Título -->
<div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
    <div>
        <nav class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-3">
            <a asp-page="/Admin/Index" class="hover:text-primary transition-colors">Admin</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-primary">Gestión de Cursos</span>
        </nav>
        <h2 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tighter">Gestión de Cursos</h2>
    </div>
    <a asp-page="/Admin/Cursos/Crear"
       class="bg-primary text-white px-6 py-3 rounded-xl font-semibold shadow-lg shadow-primary/20 flex items-center gap-2 hover:scale-[1.02] transition-transform active:scale-95">
        <span class="material-symbols-outlined">add</span>
        Nuevo Curso
    </a>
</div>

<!-- Filtros -->
<form method="get" class="flex flex-col md:flex-row gap-4 items-center mb-6">
    <!-- Búsqueda -->
    <div class="relative flex-1 w-full">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
        <input asp-for="Busqueda"
               class="w-full pl-10 pr-4 py-2.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg focus:ring-2 focus:ring-primary/20 text-sm outline-none"
               placeholder="Buscar por nombre o área..." />
    </div>

    <!-- Filtro estado -->
    <div class="flex items-center gap-3 w-full md:w-auto">
        <select asp-for="FiltroEstado"
                class="w-full md:w-48 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg py-2.5 px-3 text-sm text-slate-500 font-medium focus:ring-2 focus:ring-primary/20 outline-none">
            <option value="">Todos los estados</option>
            <option value="true">Activo</option>
            <option value="false">Inactivo</option>
        </select>
        <button type="submit"
                class="px-4 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-blue-700 transition-all">
            Buscar
        </button>
    </div>
</form>

<!-- Tabla -->
<div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Sigla</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Nombre del Curso</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Créditos</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Escuela</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400 text-center">Estado</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                @foreach (var curso in Model.cursos)
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                        <td class="px-6 py-5 font-bold text-sm text-primary">@curso.Sigla</td>
                        <td class="px-6 py-5">
                            <span class="font-semibold text-slate-900 dark:text-white">@curso.Nombre</span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-300 px-3 py-1 rounded-full text-xs font-bold tracking-tight">
                                @curso.Creditos CRED
                            </span>
                        </td>
                        <td class="px-6 py-5">
                            <span class="text-sm text-slate-600 dark:text-slate-400">@curso.Escuela</span>
                        </td>
                        <td class="px-6 py-5 text-center">
                            @if (curso.Activo)
                            {
                                <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                    <span class="text-[11px] font-bold uppercase tracking-wider">Activo</span>
                                </div>
                            }
                            else
                            {
                                <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                                    <span class="text-[11px] font-bold uppercase tracking-wider">Inactivo</span>
                                </div>
                            }
                        </td>
                        <td class="px-6 py-5 text-right">
                            <div class="flex justify-end gap-3 text-slate-400">
                                <a asp-page="/Admin/Cursos/Editar" asp-route-id="@curso.Id"
                                   class="hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                                    <span class="material-symbols-outlined text-[20px]">edit</span>
                                </a>
                                <a asp-page="/Admin/Cursos/Eliminar" asp-route-id="@curso.Id"
                                   class="hover:text-red-500 transition-colors">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    <div class="px-6 py-4 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
        <span class="text-xs text-slate-500 font-medium">
            Mostrando <span class="text-slate-900 dark:text-white">@Model.PaginaInicio-@Model.PaginaFin</span> de 
            <span class="text-slate-900 dark:text-white">@Model.TotalCursos</span> entradas
        </span>
        <div class="flex items-center gap-1">
            <a asp-page="/Admin/Cursos"
               asp-route-pagina="@(Model.PaginaActual - 1)"
               asp-route-busqueda="@Model.Busqueda"
               asp-route-filtroEstado="@Model.FiltroEstado"
               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors
                      @(Model.PaginaActual <= 1 ? "pointer-events-none opacity-40" : "")">
                <span class="material-symbols-outlined text-[18px]">chevron_left</span>
            </a>
            @for (int i = 1; i <= Model.TotalPaginas; i++)
            {
                <a asp-page="/Admin/Cursos"
                   asp-route-pagina="@i"
                   asp-route-busqueda="@Model.Busqueda"
                   asp-route-filtroEstado="@Model.FiltroEstado"
                   class="w-8 h-8 flex items-center justify-center rounded-lg text-xs font-bold transition-colors
                              @(i == Model.PaginaActual ? "bg-primary text-white" : "border border-slate-200 dark:border-slate-700 text-slate-500 hover:bg-white dark:hover:bg-slate-800")">
                    @i
                </a>
            }
            <a asp-page="/Admin/Cursos"
               asp-route-pagina="@(Model.PaginaActual + 1)"
               asp-route-busqueda="@Model.Busqueda"
               asp-route-filtroEstado="@Model.FiltroEstado"
               class="w-8 h-8 flex items-center justify-center rounded-lg border border-slate-200 dark:border-slate-700 text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors
                      @(Model.PaginaActual >= Model.TotalPaginas ? "pointer-events-none opacity-40" : "")">
                <span class="material-symbols-outlined text-[18px]">chevron_right</span>
            </a>
        </div>
    </div>
</div>

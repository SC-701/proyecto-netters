@page "/Admin/Carreras/Crear"
@model Web.Pages.Admin.Carreras.CrearModel
@{
    ViewData["Title"] = "Crear Nueva Carrera";
    ViewData["ActivePage"] = "Carreras";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="max-w-2xl mx-auto">

    <!-- Header -->
    <header class="mb-10 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">Crear Nueva Carrera</h2>
        <p class="text-slate-500 dark:text-slate-400 mt-2 text-sm">Configure los detalles arquitectónicos de una nueva carrera académica.</p>
    </header>

    <!-- Card del formulario -->
    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-8">
        <form method="post" class="space-y-10">
            @Html.AntiForgeryToken()

            <!-- Sección: Información General -->
            <div class="space-y-6">
                <div class="flex items-center gap-2 border-b border-slate-200 dark:border-slate-800 pb-2">
                    <span class="material-symbols-outlined text-[18px] text-primary">info</span>
                    <h3 class="text-[11px] font-bold uppercase tracking-widest text-slate-400">Información General</h3>
                </div>

                <div>
                    <label asp-for="carrera.Nombre"
                           class="block text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-2">
                        Nombre de la Carrera
                    </label>
                    <input asp-for="carrera.Nombre"
                           class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm focus:ring-2 focus:ring-primary/30 focus:border-primary px-4 py-2.5 transition-all placeholder:text-slate-400 outline-none"
                           placeholder="Ej. Ingeniería en Sistemas de Información" />
                    <span asp-validation-for="carrera.Nombre" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <!-- Botones -->
            <div class="flex items-center justify-end gap-4 pt-8 border-t border-slate-200 dark:border-slate-800">
                <a asp-page="/Admin/Carreras/Index"
                   class="px-6 py-2.5 text-sm font-semibold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all">
                    Cancelar
                </a>
                <button type="submit"
                        class="px-8 py-2.5 text-sm font-bold text-white bg-primary rounded-xl shadow-lg shadow-primary/20 hover:bg-blue-700 transition-all active:scale-[0.98] flex items-center gap-2">
                    Guardar Carrera
                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                </button>
            </div>
        </form>
    </div>

    <!-- Cards informativas -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-8">
        <div class="bg-primary/5 border border-primary/10 rounded-xl p-6 flex flex-col gap-3">
            <span class="material-symbols-outlined text-primary">info</span>
            <div>
                <h4 class="text-sm font-bold text-slate-900 dark:text-white">Validación de Datos</h4>
                <p class="text-[13px] text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">
                    Asegúrese de que el nombre no contenga abreviaturas no autorizadas.
                </p>
            </div>
        </div>
        <div class="bg-emerald-50 dark:bg-emerald-900/10 border border-emerald-100 dark:border-emerald-900/30 rounded-xl p-6 flex flex-col gap-3">
            <span class="material-symbols-outlined text-emerald-500">auto_awesome</span>
            <div>
                <h4 class="text-sm font-bold text-slate-900 dark:text-white">Auto-Asignación</h4>
                <p class="text-[13px] text-slate-500 dark:text-slate-400 mt-1 leading-relaxed">
                    Al guardar, se generará automáticamente un ID institucional único.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

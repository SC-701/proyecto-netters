@page "/Admin/Carreras/Eliminar/{id:guid}"
@model Web.Pages.Admin.Carreras.EliminarModel
@{
    ViewData["Title"] = "Eliminar Carrera";
    ViewData["ActivePage"] = "Carreras";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="w-full max-w-xl mx-auto">
    <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">

        <!-- Header -->
        <div class="p-8 pb-4">
            <div class="flex justify-between items-end mb-4">
                <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Eliminar Carrera</h2>
                <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 text-red-500 rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl" style='font-variation-settings: "FILL" 1;'>delete</span>
                </div>
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm pr-12">
                ¿Estás seguro de que deseas eliminar este registro de carrera? Esta acción afectará a los estudiantes y cursos vinculados.
            </p>
        </div>

        <!-- Contenido -->
        <div class="p-8">

            <!-- Datos de la carrera -->
            <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4 mb-6 border border-slate-200 dark:border-slate-700">
                <div class="flex flex-col gap-1">
                    <span class="text-[10px] uppercase tracking-wider text-slate-400 font-semibold">Nombre de la Carrera</span>
                    <p class="text-sm font-bold text-slate-900 dark:text-white">@Model.Carrera.Nombre</p>
                </div>
            </div>

            <!-- Advertencia -->
            <div class="bg-red-50 dark:bg-red-900/10 border border-red-200 dark:border-red-900/30 rounded-lg p-4 mb-6 flex gap-3 items-start">
                <span class="material-symbols-outlined text-red-500 text-xl">warning</span>
                <div>
                    <p class="text-red-900 dark:text-red-400 font-bold text-sm mb-0.5">Acción Irreversible</p>
                    <p class="text-red-700 dark:text-red-500/80 text-sm leading-relaxed">
                        Esta acción es permanente y no se puede deshacer. Se eliminarán todos los metadatos y configuraciones curriculares asociadas.
                    </p>
                </div>
            </div>

            <form method="post">
                @Html.AntiForgeryToken()

                <!-- Checkbox de confirmación -->
                <div class="mb-8">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input id="confirmCheck" type="checkbox"
                               class="h-5 w-5 rounded border-slate-300 text-red-500 focus:ring-red-500 transition-all cursor-pointer" />
                        <span class="text-sm text-slate-500 font-medium group-hover:text-slate-900 dark:group-hover:text-slate-100 transition-colors">
                            Entiendo las consecuencias de eliminar este registro
                        </span>
                    </label>
                </div>

                <!-- Botones -->
                <div class="grid grid-cols-2 gap-4">
                    <a asp-page="/Admin/Carreras/Index"
                       class="w-full bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 font-bold py-3 px-4 rounded-lg hover:bg-slate-200 dark:hover:bg-slate-700 transition-all active:scale-[0.98] text-sm text-center">
                        Cancelar
                    </a>
                    <button id="btnEliminar" type="submit" disabled
                            class="w-full bg-red-500 text-white font-bold py-3 px-4 rounded-lg shadow-sm hover:bg-red-600 transition-all active:scale-[0.98] flex items-center justify-center gap-2 text-sm
                                   disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-red-500">
                        <span class="material-symbols-outlined text-lg">delete</span>
                        Confirmar Eliminación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const check  = document.getElementById('confirmCheck');
        const btn    = document.getElementById('btnEliminar');
        check.addEventListener('change', () => btn.disabled = !check.checked);
    </script>
}

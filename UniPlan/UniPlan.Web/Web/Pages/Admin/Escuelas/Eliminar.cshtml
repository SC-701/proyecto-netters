@page "/Admin/Escuelas/Eliminar/{id:guid}"
@model Web.Pages.Admin.Escuelas.EliminarModel
@{
    ViewData["Title"] = "Eliminar Escuela";
    ViewData["ActivePage"] = "Escuelas";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="w-full max-w-md mx-auto">
    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-8 relative z-10">

        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">Eliminar Escuela</h2>
            <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center text-red-500">
                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>delete_forever</span>
            </div>
        </div>

        <!-- Datos de la escuela -->
        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700 p-5 mb-6">
            <div class="flex justify-between items-start">
                <div>
                    <span class="text-[11px] uppercase tracking-widest text-slate-400 font-bold block mb-1">Nombre de la Escuela</span>
                    <span class="text-slate-900 dark:text-white font-semibold">@Model.Escuela.Nombre</span>
                </div>
                <div class="text-right">
                    <span class="text-[11px] uppercase tracking-widest text-slate-400 font-bold block mb-1">Área Académica</span>
                    <span class="text-slate-900 dark:text-white font-semibold text-xs">@Model.Escuela.Area</span>
                </div>
            </div>
        </div>

        <!-- Advertencia -->
        <div class="bg-red-50 dark:bg-red-900/10 rounded-xl p-4 flex gap-3 mb-8 border border-red-100 dark:border-red-900/20">
            <span class="material-symbols-outlined text-red-500 shrink-0" style='font-variation-settings: "FILL" 1;'>report</span>
            <div>
                <h3 class="text-xs font-bold text-red-900 dark:text-red-400 mb-1">Acción Irreversible</h3>
                <p class="text-red-700 dark:text-red-500/80 text-[11px] leading-relaxed">
                    Al eliminar esta escuela, todos los registros asociados de <span class="font-bold">estudiantes, cursos y cronogramas</span> serán desvinculados permanentemente. Esta acción no se puede deshacer.
                </p>
            </div>
        </div>

        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <!-- Checkbox -->
            <label class="flex items-start gap-3 cursor-pointer group">
                <input id="confirmCheck" type="checkbox"
                       class="h-5 w-5 rounded border-slate-300 text-red-500 focus:ring-red-500 focus:ring-offset-0 transition-all cursor-pointer mt-0.5" />
                <span class="text-sm text-slate-500 group-hover:text-slate-900 dark:group-hover:text-slate-100 transition-colors">
                    Entiendo las consecuencias y confirmo que deseo eliminar definitivamente esta escuela del sistema.
                </span>
            </label>

            <!-- Botones -->
            <div class="grid grid-cols-2 gap-3">
                <a asp-page="/Admin/Escuelas/Index"
                   class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 font-semibold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-center">
                    Cancelar y Volver
                </a>
                <button id="btnEliminar" type="submit" disabled
                        class="w-full px-4 py-3.5 rounded-xl bg-red-500 text-white font-bold text-sm shadow-lg shadow-red-500/20 hover:bg-red-600 active:scale-95 transition-all
                               disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-red-500">
                    Confirmar Eliminación
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const check = document.getElementById('confirmCheck');
        const btn   = document.getElementById('btnEliminar');
        check.addEventListener('change', () => btn.disabled = !check.checked);
    </script>
}

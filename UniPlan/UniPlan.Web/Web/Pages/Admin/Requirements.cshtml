@page
@model Web.Pages.Admin.RequirementsModel
@{
    ViewData["Title"] = "Gestión de Requisitos";
    ViewData["ActivePage"] = "Requirements";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<!-- Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h2 class="text-3xl font-black tracking-tight text-slate-900 dark:text-white">Gestión de Requisitos</h2>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Define las dependencias académicas y flujos curriculares.</p>
    </div>
    <a asp-page="/Admin/RequirementForm"
       class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition-all shadow-lg shadow-primary/20">
        <span class="material-symbols-outlined text-lg">add</span>
        Nuevo Requisito
    </a>
</div>

<!-- Search -->
<div class="mb-6">
    <form method="get" class="relative w-full max-w-md">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xl">search</span>
        <input asp-for="Query"
               class="w-full pl-10 pr-4 py-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg text-sm focus:ring-2 focus:ring-primary/50 transition-all outline-none"
               placeholder="Buscar curso o código..." />
    </form>
</div>

<!-- Stats -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Total Cursos</p>
        <p class="text-2xl font-bold mt-1">@Model.Stats.TotalCourses</p>
    </div>
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Prerrequisitos Activos</p>
        <p class="text-2xl font-bold mt-1 text-primary">@Model.Stats.ActivePrerequisites</p>
    </div>
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Correquisitos</p>
        <p class="text-2xl font-bold mt-1">@Model.Stats.Corequisites</p>
    </div>
    <div class="bg-white dark:bg-slate-900 p-4 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-medium text-slate-500 uppercase tracking-wider">Inconsistencias</p>
        <p class="text-2xl font-bold mt-1 @(Model.Stats.Inconsistencies > 0 ? "text-red-500" : "text-green-500")">
            @Model.Stats.Inconsistencies
        </p>
    </div>
</div>

<!-- Dependency Matrix Table -->
<div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between">
        <h3 class="font-bold text-slate-800 dark:text-slate-100">Matriz de Dependencias</h3>
        <div class="flex gap-2">
            <button class="p-2 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                <span class="material-symbols-outlined text-xl">filter_list</span>
            </button>
            <a asp-page="/Admin/Requirements" asp-page-handler="Export"
               class="p-2 border border-slate-200 dark:border-slate-700 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors">
                <span class="material-symbols-outlined text-xl">download</span>
            </a>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Curso</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Código</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Prerrequisitos</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Correquisitos</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                @foreach (var row in Model.Requirements)
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                        <td class="px-6 py-4">
                            <div class="font-medium text-slate-900 dark:text-slate-100">@row.CourseName</div>
                            <div class="text-xs text-slate-500">@row.Department</div>
                        </td>
                        <td class="px-6 py-4 text-sm font-mono text-slate-600 dark:text-slate-400">@row.Code</td>

                        <!-- Prerrequisitos -->
                        <td class="px-6 py-4">
                            @if (row.Prerequisites.Any())
                            {
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var pre in row.Prerequisites)
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary">
                                            @pre
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300">
                                    Ninguno
                                </span>
                            }
                        </td>

                        <!-- Correquisitos -->
                        <td class="px-6 py-4">
                            @if (row.Corequisites.Any())
                            {
                                <div class="flex flex-wrap gap-1">
                                    @foreach (var co in row.Corequisites)
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300">
                                            @co
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-sm text-slate-400">—</span>
                            }
                        </td>

                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-1">
                                <a asp-page="/Admin/RequirementForm" asp-route-id="@row.Id"
                                   class="p-1.5 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all">
                                    <span class="material-symbols-outlined text-xl">edit</span>
                                </a>
                                <form method="post" asp-page-handler="Delete" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@row.Id" />
                                    <button type="submit"
                                            onclick="return confirm('¿Eliminar el requisito de @row.CourseName?')"
                                            class="p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-all">
                                        <span class="material-symbols-outlined text-xl">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="px-6 py-4 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
        <p class="text-xs text-slate-500 font-medium">
            Mostrando @Model.PageStart-@Model.PageEnd de @Model.Stats.TotalCourses cursos
        </p>
        <div class="flex gap-2">
            <a asp-page="/Admin/Requirements"
               asp-route-page="@(Model.CurrentPage - 1)"
               asp-route-query="@Model.Query"
               class="px-3 py-1 text-xs font-bold border border-slate-300 dark:border-slate-700 rounded hover:bg-white dark:hover:bg-slate-800 transition-colors
                      @(Model.CurrentPage <= 1 ? "pointer-events-none opacity-40" : "")">
                Anterior
            </a>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-page="/Admin/Requirements"
                   asp-route-page="@i"
                   asp-route-query="@Model.Query"
                   class="px-3 py-1 text-xs font-bold rounded transition-colors
                              @(i == Model.CurrentPage ? "bg-primary text-white shadow-sm" : "border border-slate-300 dark:border-slate-700 hover:bg-white dark:hover:bg-slate-800")">
                    @i
                </a>
            }
            <a asp-page="/Admin/Requirements"
               asp-route-page="@(Model.CurrentPage + 1)"
               asp-route-query="@Model.Query"
               class="px-3 py-1 text-xs font-bold border border-slate-300 dark:border-slate-700 rounded hover:bg-white dark:hover:bg-slate-800 transition-colors
                      @(Model.CurrentPage >= Model.TotalPages ? "pointer-events-none opacity-40" : "")">
                Siguiente
            </a>
        </div>
    </div>
</div>


<!-- FAB mobile -->
<div class="fixed bottom-8 right-8 lg:hidden">
    <a asp-page="/Admin/RequirementForm"
       class="w-14 h-14 bg-primary text-white rounded-full shadow-lg flex items-center justify-center hover:scale-105 transition-transform">
        <span class="material-symbols-outlined">add</span>
    </a>
</div>

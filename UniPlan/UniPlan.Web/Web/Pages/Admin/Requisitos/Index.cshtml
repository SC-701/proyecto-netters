@page "/Admin/Requisitos"
@model Web.Pages.Admin.Requisitos.IndexModel
@{
    ViewData["Title"] = "Gestión de Requisitos";
    ViewData["ActivePage"] = "Requisitos";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
    <div>
        <nav class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-3">
            <a asp-page="/Admin/Index" class="hover:text-primary transition-colors">Admin</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-primary">Requisitos</span>
        </nav>
        <h2 class="text-4xl font-extrabold text-slate-900 dark:text-white tracking-tighter">Gestión de Requisitos</h2>
    </div>
    <a asp-page="/Admin/Requisitos/Crear"
           class="bg-primary text-white px-6 py-3 rounded-xl font-semibold shadow-lg shadow-primary/20 flex items-center gap-2 hover:scale-[1.02] transition-transform active:scale-95">
        <span class="material-symbols-outlined">add</span>
        Nuevo Requisito
    </a>
</div>

<form method="get" class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end mb-6">
    <div>
        <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-2">Carrera</label>
        <select asp-for="IdCarrera" asp-items="Model.ListaCarreras"
                class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg py-2.5 px-3 text-sm outline-none">
            <option value="">Seleccione una carrera</option>
        </select>
    </div>

    <div>
        <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-2">Curso</label>
        <select asp-for="IdCurso" asp-items="Model.ListaCursos"
                class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg py-2.5 px-3 text-sm outline-none">
            <option value="">Seleccione un curso</option>
        </select>
    </div>

    <div>
        <button type="submit"
                class="px-4 py-2.5 bg-primary text-white text-sm font-bold rounded-lg hover:bg-blue-700 transition-all w-full">
            Buscar
        </button>
    </div>
</form>

<div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full border-collapse text-left">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Carrera</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Curso</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400">Requisito</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400 text-center">Tipo</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400 text-center">Estado</th>
                    <th class="px-6 py-4 text-[11px] uppercase tracking-widest font-bold text-slate-400 text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
                @if (Model.requisitos.Any())
                {
                    @foreach (var requisito in Model.requisitos)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition-colors">
                            <td class="px-6 py-5">@requisito.Carrera</td>
                            <td class="px-6 py-5">@requisito.SiglaCurso - @requisito.Curso</td>
                            <td class="px-6 py-5">@requisito.SiglaRequisito - @requisito.CursoRequisito</td>
                            <td class="px-6 py-5 text-center">
                                @(requisito.EsCorequisito ? "Corequisito" : "Requisito")
                            </td>
                            <td class="px-6 py-5 text-center">
                                @(requisito.Activo ? "Activo" : "Inactivo")
                            </td>



                            <td class="px-6 py-5 text-right">
                                <div class="flex justify-end items-center gap-3 text-slate-400">
                                    <a asp-page="/Admin/Requisitos/Editar"
                                           asp-route-idCarrera="@requisito.IdCarrera"
                                           asp-route-idCurso="@requisito.IdCurso"
                                           asp-route-idCursoRequisito="@requisito.IdCursoRequisito"
                                           class="hover:text-slate-600 dark:hover:text-slate-200 transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>

                                    <a asp-page="/Admin/Requisitos/Eliminar"
                                           asp-route-idCarrera="@requisito.IdCarrera"
                                           asp-route-idCurso="@requisito.IdCurso"
                                           asp-route-idCursoRequisito="@requisito.IdCursoRequisito"
                                           class="hover:text-red-500 transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </a>

                                    <form method="post" asp-page-handler="CambiarEstado" class="inline">
                                        <input type="hidden" name="idCarrera" value="@requisito.IdCarrera" />
                                        <input type="hidden" name="idCurso" value="@requisito.IdCurso" />
                                        <input type="hidden" name="idCursoRequisito" value="@requisito.IdCursoRequisito" />
                                        <input type="hidden" name="activo" value="@(!requisito.Activo)" />

                                        <button type="submit"
                                                class="hover:text-emerald-500 transition-colors"
                                                title="@(requisito.Activo ? "Inactivar" : "Activar")">
                                            <span class="material-symbols-outlined text-[20px]">
                                                @(requisito.Activo ? "toggle_off" : "toggle_on")
                                            </span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-6 py-8 text-center text-slate-500">
                            No hay requisitos para mostrar.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@page "/Admin/Requisitos/Editar"
@model Web.Pages.Admin.Requisitos.EditarModel
@{
    ViewData["Title"] = "Editar Requisito";
    ViewData["ActivePage"] = "Requisitos";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="max-w-2xl mx-auto">
    <header class="mb-10 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white leading-tight">Editar Requisito</h2>
        <p class="text-slate-500 dark:text-slate-400 mt-2 text-sm">Modifique la relación entre el curso y su requisito o corequisito.</p>
    </header>

    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-8">
        <form method="post" class="space-y-8">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="requisito.IdCarrera" />
            <input type="hidden" asp-for="requisito.IdCurso" />
            <input type="hidden" asp-for="requisito.IdCursoRequisito" />

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-2">Carrera</label>
                <input value="@Model.NombreCarrera"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2.5 text-sm"
                       disabled />
            </div>

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-2">Curso</label>
                <input value="@Model.NombreCurso"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2.5 text-sm"
                       disabled />
            </div>

            <div>
                <label class="block text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-2">Curso Requisito</label>
                <input value="@Model.NombreCursoRequisito"
                       class="w-full bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg px-4 py-2.5 text-sm"
                       disabled />
            </div>

            <div class="flex items-center gap-3">
                <input asp-for="requisito.EsCorequisito" class="h-4 w-4" />
                <label asp-for="requisito.EsCorequisito" class="text-sm text-slate-600 dark:text-slate-300">
                    Es corequisito
                </label>
            </div>

            <div class="flex items-center justify-end gap-4 pt-8 border-t border-slate-200 dark:border-slate-800">
                <a asp-page="/Admin/Requisitos/Index"
                       asp-route-idCarrera="@Model.requisito.IdCarrera"
                       asp-route-idCurso="@Model.requisito.IdCurso"
                       class="px-6 py-2.5 text-sm font-semibold text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-xl transition-all">
                    Cancelar
                </a>
                <button type="submit"
                        class="px-8 py-2.5 text-sm font-bold text-white bg-primary rounded-xl shadow-lg shadow-primary/20 hover:bg-blue-700 transition-all">
                    Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
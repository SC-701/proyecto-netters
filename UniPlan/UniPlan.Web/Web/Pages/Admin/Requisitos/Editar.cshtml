@page "/Admin/Requisitos/Editar"
@model Web.Pages.Admin.Requisitos.EditarModel
@{
    ViewData["Title"] = "Editar Requisito";
    ViewData["ActivePage"] = "Requisitos";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="w-full max-w-4xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-2">Editar Requisito</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm max-w-2xl mx-auto">
            Modifique las dependencias académicas entre cursos.
        </p>
    </div>

    <!-- Card -->
    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl shadow-sm overflow-hidden">
        <div class="p-8 md:p-12">

            <div class="mb-8 space-y-3">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-[20px]">info</span>
                    <span class="text-[11px] font-bold text-slate-400 uppercase tracking-widest">Información General</span>
                </div>
                <div class="h-px w-full bg-slate-200 dark:bg-slate-800"></div>
            </div>

            <form method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">

                    <!-- Carrera -->
                    <div class="space-y-2">
                        <label asp-for="Input.IdCarrera"
                               class="text-[11px] font-bold text-slate-900 dark:text-white uppercase tracking-widest block px-1">
                            Carrera
                        </label>
                        <div class="relative">
                            <select asp-for="Input.IdCarrera"
                                    asp-items="Model.CarreraOptions"
                                    class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all cursor-pointer outline-none">
                                <option value="">Seleccione una carrera</option>
                            </select>
                            
                        </div>
                        <span asp-validation-for="Input.IdCarrera" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Curso -->
                    <div class="space-y-2">
                        <label asp-for="Input.IdCurso"
                               class="text-[11px] font-bold text-slate-900 dark:text-white uppercase tracking-widest block px-1">
                            Curso
                        </label>
                        <div class="relative">
                            <select asp-for="Input.IdCurso"
                                    asp-items="Model.CursoOptions"
                                    class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all cursor-pointer outline-none">
                                <option value="">Seleccione un curso</option>
                            </select>
                            
                        </div>
                        <span asp-validation-for="Input.IdCurso" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Curso Requisito -->
                    <div class="space-y-2 md:col-span-2">
                        <label asp-for="Input.IdCursoRequisito"
                               class="text-[11px] font-bold text-slate-900 dark:text-white uppercase tracking-widest block px-1">
                            Curso Requisito
                        </label>
                        <div class="relative">
                            <select asp-for="Input.IdCursoRequisito"
                                    asp-items="Model.CursoRequisitoOptions"
                                    class="w-full bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl py-3.5 px-4 text-sm appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all cursor-pointer outline-none">
                                <option value="">Seleccione el curso requisito</option>
                            </select>
                            
                        </div>
                        <span asp-validation-for="Input.IdCursoRequisito" class="text-xs text-red-500 mt-1 block"></span>
                    </div>

                    <!-- Toggle Correquisito -->
                    <div class="md:col-span-2 pt-2 flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700">
                        <div class="flex flex-col">
                            <span class="text-sm font-bold text-slate-900 dark:text-white">Es correquisito</span>
                            <span class="text-[11px] text-slate-500 dark:text-slate-400">¿El curso debe llevarse simultáneamente con el requisito?</span>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input asp-for="Input.EsCorequisito" type="checkbox" class="sr-only peer" />
                            <div class="w-12 h-6 bg-slate-300 dark:bg-slate-600 peer-focus:outline-none rounded-full peer
                                        peer-checked:after:translate-x-full peer-checked:after:border-white
                                        after:content-[''] after:absolute after:top-[2px] after:left-[2px]
                                        after:bg-white after:border after:rounded-full after:h-5 after:w-5
                                        after:transition-all peer-checked:bg-primary"></div>
                        </label>
                    </div>
                </div>

                <!-- Botones -->
                <div class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-800 flex items-center justify-end gap-4">
                    <a asp-page="/Admin/Requisitos/Index"
                       class="px-6 py-3 text-sm font-semibold text-slate-500 hover:text-slate-900 dark:hover:text-slate-100 transition-colors">
                        Cancelar
                    </a>
                    <button type="submit"
                            class="px-8 py-3 bg-primary text-white rounded-xl text-sm font-bold shadow-lg shadow-primary/20 hover:bg-blue-700 active:scale-95 transition-all">
                        Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

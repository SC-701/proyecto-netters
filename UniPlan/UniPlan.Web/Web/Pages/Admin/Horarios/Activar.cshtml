@page "/Admin/Horarios/Activar/{id:guid}"
@model Web.Pages.Admin.Horarios.ActivarModel
@{
    ViewData["Title"] = "Activar Horario";
    ViewData["ActivePage"] = "Horarios";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<div class="w-full max-w-md mx-auto">
    <div class="bg-white dark:bg-slate-900 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-8 relative z-10">

        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 dark:text-white">
                Activar Horario
            </h2>
            <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-green-500">
                <span class="material-symbols-outlined" style='font-variation-settings: "FILL" 1;'>check_circle</span>
            </div>
        </div>

        <p class="text-slate-500 dark:text-slate-400 text-sm mb-6 leading-relaxed">
            Estás a punto de activar este horario en el sistema. Volverá a estar disponible para su uso.
        </p>

        <!-- Datos del horario -->
        <div class="bg-slate-50 dark:bg-slate-800/50 rounded-xl border border-slate-200 dark:border-slate-700 p-5 mb-6">
            <div class="flex flex-col gap-4">
                <div class="flex justify-between items-center">
                    <div>
                        <span class="text-[11px] uppercase tracking-widest text-slate-400 font-bold block mb-1">
                            Día Académico
                        </span>
                        <span class="text-slate-900 dark:text-white font-semibold">
                            @Model.Horario.Dia
                        </span>
                    </div>
                    <div class="text-right">
                        <span class="text-[11px] uppercase tracking-widest text-slate-400 font-bold block mb-1">
                            Franja Horaria
                        </span>
                        <span class="text-slate-900 dark:text-white font-semibold">
                            @Model.Horario.HoraEntrada:00 - @Model.Horario.HoraSalida:00
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info -->
        <div class="bg-green-50 dark:bg-green-900/10 rounded-xl p-4 flex gap-3 mb-8 border border-green-100 dark:border-green-900/20">
            <span class="material-symbols-outlined text-green-500" style='font-variation-settings: "FILL" 1;'>info</span>
            <p class="text-green-700 dark:text-green-400 text-xs font-medium leading-relaxed">
                Al activar este horario, estará nuevamente disponible para asignaciones y gestión académica.
            </p>
        </div>

        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <!-- Checkbox -->
            <label class="flex items-start gap-3 cursor-pointer group">
                <input id="confirmCheck" type="checkbox"
                       class="h-5 w-5 rounded border-slate-300 text-green-500 focus:ring-green-500 focus:ring-offset-0 transition-all cursor-pointer mt-0.5" />
                <span class="text-sm text-slate-500 group-hover:text-slate-900 dark:group-hover:text-slate-100 transition-colors">
                    Confirmo que deseo activar este horario.
                </span>
            </label>

            <!-- Botones -->
            <div class="grid grid-cols-2 gap-4">
                <a asp-page="/Admin/Horarios/Index"
                   class="px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-900 dark:text-slate-100 font-semibold text-sm hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-center">
                    Cancelar
                </a>
                <button id="btnActivar" type="submit" disabled
                        class="px-4 py-3 rounded-xl bg-green-500 text-white font-semibold text-sm shadow-lg shadow-green-500/20 hover:bg-green-600 active:scale-95 transition-all
                               disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-green-500">
                    Confirmar Activación
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const check = document.getElementById('confirmCheck');
        const btn = document.getElementById('btnActivar');
        check.addEventListener('change', () => btn.disabled = !check.checked);
    </script>
}
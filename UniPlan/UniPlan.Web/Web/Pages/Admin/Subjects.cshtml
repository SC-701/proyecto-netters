@page
@model Web.Pages.Admin.SubjectsModel
@{
    ViewData["Title"] = "Gestión de Asignaturas";
    ViewData["ActivePage"] = "Subjects";
    ViewData["AdminName"] = Model.AdminName;
    ViewData["AdminEmail"] = Model.AdminEmail;
    Layout = "_AdminLayout";
}

<!-- Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h2 class="text-3xl font-black tracking-tight">Gestión de Asignaturas</h2>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Administra el catálogo académico de la institución.</p>
    </div>
    <a asp-page="/Admin/SubjectForm"
       class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-white font-bold rounded-xl hover:opacity-90 transition-all shadow-lg shadow-primary/20">
        <span class="material-symbols-outlined">add</span>
        Nueva Asignatura
    </a>
</div>

<!-- Filters & Search -->
<div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm space-y-4 mb-8">
    <form method="get" class="grid grid-cols-1 md:grid-cols-12 gap-4">

        <!-- Búsqueda -->
        <div class="md:col-span-5 relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
            <input asp-for="Filter.Query"
                   class="w-full pl-10 pr-4 py-2.5 bg-background-light dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 transition-all text-sm outline-none"
                   placeholder="Buscar por código o nombre..." />
        </div>

        <!-- Carrera -->
        <div class="md:col-span-3 relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">work</span>
            <select asp-for="Filter.CareerId"
                    asp-items="Model.CareerOptions"
                    class="w-full pl-10 pr-10 py-2.5 bg-background-light dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 appearance-none text-sm cursor-pointer outline-none">
                <option value="">Todas las Carreras</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
        </div>

        <!-- Semestre -->
        <div class="md:col-span-2 relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">calendar_month</span>
            <select asp-for="Filter.Semester"
                    class="w-full pl-10 pr-10 py-2.5 bg-background-light dark:bg-slate-800 border-none rounded-xl focus:ring-2 focus:ring-primary/50 appearance-none text-sm cursor-pointer outline-none">
                <option value="">Todos los Semestres</option>
                <option value="1">Primer Semestre</option>
                <option value="2">Segundo Semestre</option>
            </select>
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">expand_more</span>
        </div>

        <!-- Botón filtrar -->
        <div class="md:col-span-2">
            <button type="submit"
                    class="w-full flex items-center justify-center gap-2 py-2.5 px-4 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-xl font-semibold text-sm hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
                <span class="material-symbols-outlined text-lg">filter_list</span>
                Filtros
            </button>
        </div>
    </form>

    <!-- Active filter chips -->
    @if (Model.ActiveFilters.Any())
    {
        <div class="flex flex-wrap gap-2 items-center">
            @foreach (var chip in Model.ActiveFilters)
            {
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full">
                    @chip.Label
                    <a asp-page="/Admin/Subjects"
                       asp-all-route-data="chip.RemoveParams"
                       class="material-symbols-outlined text-[14px] leading-none cursor-pointer">close</a>
                </span>
            }
            <a asp-page="/Admin/Subjects" class="text-xs text-slate-500 hover:text-primary underline">Limpiar todos</a>
        </div>
    }
</div>

<!-- Table -->
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-800">
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Código</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Nombre de Asignatura</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Créditos</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Carrera</th>
                    <th class="px-6 py-4 text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider text-right">Acciones</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                @foreach (var subject in Model.Subjects)
                {
                    <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
                        <td class="px-6 py-4">
                            <span class="font-mono text-sm font-semibold text-primary">@subject.Code</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold">@subject.Name</span>
                                <span class="text-xs text-slate-500">@subject.Mention</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300">
                                @subject.Credits Créditos
                            </span>
                        </td>
                        <td class="px-6 py-4">
                            <span class="text-sm">@subject.Career</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex justify-end gap-2">
                                <a asp-page="/Admin/SubjectForm" asp-route-id="@subject.Id"
                                   class="p-1.5 text-slate-400 hover:text-primary transition-colors">
                                    <span class="material-symbols-outlined">edit</span>
                                </a>
                                <form method="post" asp-page-handler="Delete" class="inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@subject.Id" />
                                    <button type="submit"
                                            onclick="return confirm('¿Eliminar @subject.Name?')"
                                            class="p-1.5 text-slate-400 hover:text-red-500 transition-colors">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="px-6 py-4 bg-slate-50 dark:bg-slate-800/50 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between">
        <p class="text-xs text-slate-500 font-medium">
            Mostrando @Model.PageStart a @Model.PageEnd de @Model.TotalSubjects asignaturas
        </p>
        <div class="flex gap-2">
            <a asp-page="/Admin/Subjects"
               asp-route-page="@(Model.CurrentPage - 1)"
               asp-route-query="@Model.Filter.Query"
               asp-route-careerId="@Model.Filter.CareerId"
               asp-route-semester="@Model.Filter.Semester"
               class="px-3 py-1 text-xs font-bold border border-slate-300 dark:border-slate-700 rounded hover:bg-white dark:hover:bg-slate-800 transition-colors
                      @(Model.CurrentPage <= 1 ? "pointer-events-none opacity-40" : "")">
                Anterior
            </a>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-page="/Admin/Subjects"
                   asp-route-page="@i"
                   asp-route-query="@Model.Filter.Query"
                   asp-route-careerId="@Model.Filter.CareerId"
                   asp-route-semester="@Model.Filter.Semester"
                   class="px-3 py-1 text-xs font-bold rounded transition-colors
                              @(i == Model.CurrentPage ? "bg-primary text-white shadow-sm" : "border border-slate-300 dark:border-slate-700 hover:bg-white dark:hover:bg-slate-800")">
                    @i
                </a>
            }
            <a asp-page="/Admin/Subjects"
               asp-route-page="@(Model.CurrentPage + 1)"
               asp-route-query="@Model.Filter.Query"
               asp-route-careerId="@Model.Filter.CareerId"
               asp-route-semester="@Model.Filter.Semester"
               class="px-3 py-1 text-xs font-bold border border-slate-300 dark:border-slate-700 rounded hover:bg-white dark:hover:bg-slate-800 transition-colors
                      @(Model.CurrentPage >= Model.TotalPages ? "pointer-events-none opacity-40" : "")">
                Siguiente
            </a>
        </div>
    </div>
</div>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#2463eb",
                        "background-light": "#f6f6f8",
                        "background-dark": "#111621",
                    },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: {
                        "DEFAULT": "0.25rem", "lg": "0.5rem",
                        "xl": "0.75rem", "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .active-nav {
            background-color: rgba(36, 99, 235, 0.1);
            color: #2463eb;
        }
    </style>
    <title>@ViewData["Title"] - UniPlan</title>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100">
    <div class="flex min-h-screen">

        <!-- SIDEBAR -->
        <aside class="w-64 border-r border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex flex-col fixed h-full">
            <div class="p-6 flex items-center gap-3">
                <div class="size-8 rounded-lg bg-primary flex items-center justify-center text-white">
                    <span class="material-symbols-outlined">school</span>
                </div>
                <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">UniPlan</h1>
            </div>

            <nav class="flex-1 px-4 space-y-1">
                <a asp-page="/App/Dashboard"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors
                      @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active-nav font-medium" : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span>Dashboard</span>
                </a>
                <a asp-page="/App/Planner"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors
                      @(ViewData["ActivePage"]?.ToString() == "Planner" ? "active-nav font-medium" : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Planificador</span>
                </a>
                <a asp-page="/App/Schedule"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors
                      @(ViewData["ActivePage"]?.ToString() == "Schedule" ? "active-nav font-medium" : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                    <span class="material-symbols-outlined">schedule</span>
                    <span>Horario</span>
                </a>
                <a asp-page="/App/Timeline"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors
                      @(ViewData["ActivePage"]?.ToString() == "Timeline" ? "active-nav font-medium" : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                    <span class="material-symbols-outlined">timeline</span>
                    <span>Línea de Tiempo</span>
                </a>
                <a asp-page="/App/Profile"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg transition-colors
                      @(ViewData["ActivePage"]?.ToString() == "Profile" ? "active-nav font-medium" : "text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800")">
                    <span class="material-symbols-outlined">person</span>
                    <span>Perfil</span>
                </a>
            </nav>

            <!-- User info -->
            <div class="p-4 border-t border-slate-200 dark:border-slate-800">
                <a asp-page="/App/Profile"
                   class="flex items-center gap-3 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 cursor-pointer transition-colors">
                    <div class="size-9 rounded-full bg-slate-200 dark:bg-slate-700 overflow-hidden flex-shrink-0">
                        @if (!string.IsNullOrEmpty(ViewData["UserAvatar"]?.ToString()))
                        {
                            <img src="@ViewData["UserAvatar"]" alt="Avatar" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="material-symbols-outlined w-full h-full flex items-center justify-center text-slate-400">person</span>
                        }
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold truncate">@ViewData["UserName"]</p>
                        <p class="text-xs text-slate-500 truncate">@ViewData["UserCareer"]</p>
                    </div>
                </a>
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="ml-64 flex-1 p-8 lg:p-12">
            @RenderBody()
        </main>

    </div>
    @RenderSection("Scripts", required: false)
</body>
</html>
